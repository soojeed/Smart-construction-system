generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  ADMIN
  ENGINEER
  PROCUREMENT
  SUPERVISOR
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum POStatus {
  PENDING
  ORDERED
  RECEIVED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id            Int      @id @default(autoincrement())
  fullName      String
  email         String   @unique
  passwordHash  String
  role          Role     @default(ENGINEER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  managedProjects   Project[]        @relation("ProjectManager")
  materialRequests  MaterialRequest[]
  expenses          Expense[]
  dailyLogs         DailyLog[]
}

//////////////////////////////////////////////////////
// PROJECT
//////////////////////////////////////////////////////

model Project {
  id           Int           @id @default(autoincrement())
  projectName  String
  location     String?
  totalBudget  Decimal       @default(0)
  startDate    DateTime
  endDate      DateTime?
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())

  managerId    Int?
  manager      User?         @relation("ProjectManager", fields: [managerId], references: [id])

  subTasks     SubTask[]
  purchaseOrders PurchaseOrder[]
  inventory    Inventory[]
  materialRequests MaterialRequest[]
  expenses     Expense[]
  attendance   Attendance[]
  dailyLogs    DailyLog[]
  equipment    Equipment[]
}

//////////////////////////////////////////////////////
// SUB TASK
//////////////////////////////////////////////////////

model SubTask {
  id          Int        @id @default(autoincrement())
  projectId   Int
  taskName    String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      TaskStatus @default(PENDING)

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// SUPPLIER
//////////////////////////////////////////////////////

model Supplier {
  id            Int      @id @default(autoincrement())
  supplierName  String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  category      String?

  purchaseOrders PurchaseOrder[]
}

//////////////////////////////////////////////////////
// PURCHASE ORDER
//////////////////////////////////////////////////////

model PurchaseOrder {
  id          Int      @id @default(autoincrement())
  orderNumber String   @unique
  status      POStatus @default(PENDING)
  totalAmount Decimal  @default(0)
  orderDate   DateTime @default(now())

  projectId   Int
  supplierId  Int

  project     Project  @relation(fields: [projectId], references: [id])
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  items       POItem[]
  payments    SupplierPayment[]
}

model POItem {
  id             Int      @id @default(autoincrement())
  itemDescription String
  quantity        Decimal
  unitPrice       Decimal

  orderId         Int
  order           PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// SUPPLIER PAYMENT
//////////////////////////////////////////////////////

model SupplierPayment {
  id            Int      @id @default(autoincrement())
  amountPaid    Decimal
  paymentMethod String?
  paymentDate   DateTime @default(now())

  orderId       Int
  order         PurchaseOrder @relation(fields: [orderId], references: [id])
}

//////////////////////////////////////////////////////
// INVENTORY
//////////////////////////////////////////////////////

model Inventory {
  id              Int      @id @default(autoincrement())
  itemName        String
  currentQuantity Decimal  @default(0)
  unit            String?
  minStockLevel   Decimal  @default(10)
  lastUpdated     DateTime @default(now())

  projectId       Int
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// MATERIAL REQUEST
//////////////////////////////////////////////////////

model MaterialRequest {
  id          Int           @id @default(autoincrement())
  status      RequestStatus @default(PENDING)
  requestDate DateTime      @default(now())

  projectId   Int
  requesterId Int

  project     Project       @relation(fields: [projectId], references: [id])
  requester   User          @relation(fields: [requesterId], references: [id])

  items       RequestItem[]
}

model RequestItem {
  id                Int      @id @default(autoincrement())
  itemName          String
  quantityRequested Decimal

  requestId         Int
  request           MaterialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// EQUIPMENT
//////////////////////////////////////////////////////

model Equipment {
  id        Int      @id @default(autoincrement())
  name      String
  type      String?
  dailyRate Decimal?
  status    String   @default("AVAILABLE")

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

//////////////////////////////////////////////////////
// EXPENSE
//////////////////////////////////////////////////////

model Expense {
  id           Int      @id @default(autoincrement())
  category     String?
  amount       Decimal
  description  String?
  expenseDate  DateTime @default(now())

  projectId    Int
  recordedById Int

  project      Project  @relation(fields: [projectId], references: [id])
  recordedBy   User     @relation(fields: [recordedById], references: [id])
}

//////////////////////////////////////////////////////
// LABOR & ATTENDANCE
//////////////////////////////////////////////////////

model Labor {
  id        Int      @id @default(autoincrement())
  fullName  String
  trade     String?
  dailyWage Decimal

  attendance Attendance[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  workDate  DateTime @default(now())
  status    String?

  laborId   Int
  projectId Int

  labor     Labor   @relation(fields: [laborId], references: [id])
  project   Project @relation(fields: [projectId], references: [id])
}

//////////////////////////////////////////////////////
// DAILY LOG
//////////////////////////////////////////////////////

model DailyLog {
  id            Int      @id @default(autoincrement())
  reportDate    DateTime @default(now())
  workSummary   String
  manpowerCount Int?
  weather       String?

  projectId     Int
  engineerId    Int

  project       Project @relation(fields: [projectId], references: [id])
  engineer      User    @relation(fields: [engineerId], references: [id])

  photos        LogPhoto[]
}

model LogPhoto {
  id      Int @id @default(autoincrement())
  url     String
  caption String?

  logId   Int
  log     DailyLog @relation(fields: [logId], references: [id], onDelete: Cascade)
}